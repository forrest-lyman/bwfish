rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOptionalString(field, maxLen) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string
          && request.resource.data[field].size() <= maxLen);
    }

    function allowedUserProfileKeys() {
      return ['uid', 'displayName', 'photoUrl', 'boat', 'homePort', 'website', 'location'];
    }

    function hasAllowedUserProfileKeys() {
      return request.resource.data.keys().hasOnly(allowedUserProfileKeys());
    }

    function isOptionalHomePort() {
      return !('homePort' in request.resource.data)
        || (request.resource.data.homePort is map
          && request.resource.data.homePort.keys().hasOnly(['regionId', 'portId'])
          && request.resource.data.homePort.regionId is string
          && request.resource.data.homePort.regionId.size() > 0
          && request.resource.data.homePort.regionId.size() <= 64
          && request.resource.data.homePort.portId is string
          && request.resource.data.homePort.portId.size() > 0
          && request.resource.data.homePort.portId.size() <= 64);
    }

    function isValidUserProfile(userId) {
      let data = request.resource.data;
      return hasAllowedUserProfileKeys()
        && data.keys().hasAll(['uid', 'displayName'])
        && data.uid == userId
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 100
        && isOptionalString('photoUrl', 2048)
        && isOptionalString('boat', 120)
        && isOptionalString('location', 120)
        && isOptionalHomePort()
        && isOptionalString('website', 2048);
    }

    function isValidUserProfileUpdate(userId) {
      return request.auth.uid == userId
        && resource.data.uid == userId
        && request.resource.data.uid == userId
        && hasAllowedUserProfileKeys()
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 100
        && isOptionalString('photoUrl', 2048)
        && isOptionalString('boat', 120)
        && isOptionalString('location', 120)
        && isOptionalHomePort()
        && isOptionalString('website', 2048)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'photoUrl', 'boat', 'homePort', 'website', 'location']);
    }

    function feedScore(entry) {
      return entry.keys().hasAny(['score']) && entry.score is int ? entry.score : 0;
    }

    function isValidFeedScoreVoteUpdate() {
      let diff = request.resource.data.diff(resource.data);
      let scoreDelta = request.resource.data.score - feedScore(resource.data);
      return diff.affectedKeys().hasOnly(['score'])
        && request.resource.data.score is int
        && scoreDelta in [-2, -1, 1, 2];
    }

    function isValidFeedEntryOwnerUpdate() {
      let diff = request.resource.data.diff(resource.data);
      return request.auth.uid == resource.data.createdBy
        && request.auth.uid == request.resource.data.createdBy
        && request.resource.data.type == resource.data.type
        && request.resource.data.collection == resource.data.collection
        && request.resource.data.refId == resource.data.refId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 3
        && request.resource.data.lastModified is string
        && diff.affectedKeys().hasOnly(['text', 'lastModified']);
    }

    function isValidFeedVoteCreate(voteId) {
      let data = request.resource.data;
      return voteId == data.entryId + '_' + request.auth.uid
        && data.keys().hasOnly(['entryId', 'userId', 'value', 'createdAt'])
        && data.entryId is string
        && data.userId == request.auth.uid
        && data.value in [1, -1]
        && data.createdAt is string
        && exists(/databases/$(database)/documents/feed/$(data.entryId));
    }

    function isValidFeedVoteUpdate() {
      let diff = request.resource.data.diff(resource.data);
      return request.auth.uid == resource.data.userId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.entryId == resource.data.entryId
        && request.resource.data.createdAt == resource.data.createdAt
        && diff.affectedKeys().hasOnly(['value'])
        && request.resource.data.value in [1, -1];
    }

    match /regions/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /ports/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /spots/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /fish/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /techniques/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /pages/{id} {
      allow read: if true;
      allow write: if false;

      match /drafts/{draftId} {
        allow read: if true;
        allow write: if false;
      }

      match /versions/{versionId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /feed/{entryId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.createdBy
        && request.resource.data.keys().hasAll(['type','text','collection','refId','createdBy','createdAt','lastModified']);
      allow update: if request.auth != null
        && (
          isValidFeedEntryOwnerUpdate()
          || isValidFeedScoreVoteUpdate()
        );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }

    match /feed_votes/{voteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && isValidFeedVoteCreate(voteId);
      allow update: if request.auth != null
        && isValidFeedVoteUpdate();
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && isValidUserProfile(userId);
      allow update: if request.auth != null
        && request.auth.uid == userId
        && isValidUserProfileUpdate(userId);
      allow delete: if false;
    }

    // deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
